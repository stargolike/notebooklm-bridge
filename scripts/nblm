#!/usr/bin/env python3
"""NotebookLM client — lightweight, talks to the persistent server."""

import sys
import json
import time
from pathlib import Path
import subprocess
import os

CMD_FILE = Path("/tmp/nblm_cmd.json")
RESULT_FILE = Path("/tmp/nblm_result.json")
LOCK_FILE = Path("/tmp/nblm.lock")
SERVER_SCRIPT = Path(__file__).parent / "server.py"


def ensure_server():
    if LOCK_FILE.exists():
        return
    subprocess.Popen(
        [sys.executable, str(SERVER_SCRIPT)],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    for _ in range(30):
        if LOCK_FILE.exists():
            return
        time.sleep(0.5)
    print("Server failed to start.", file=sys.stderr)
    sys.exit(1)


def send(cmd):
    ensure_server()
    CMD_FILE.unlink(missing_ok=True)
    RESULT_FILE.unlink(missing_ok=True)
    CMD_FILE.write_text(json.dumps(cmd, ensure_ascii=False))
    for _ in range(120):
        if RESULT_FILE.exists():
            result = json.loads(RESULT_FILE.read_text())
            RESULT_FILE.unlink(missing_ok=True)
            return result
        time.sleep(0.5)
    return {"ok": False, "error": "timeout"}


def main():
    if len(sys.argv) < 2:
        print("Usage: nblm <command> [args...]")
        print("  nblm list")
        print("  nblm query <notebook> <question>")
        print("  nblm sources <notebook>")
        print("  nblm add-url <notebook> <url>")
        print("  nblm add-text <notebook> <title> <text>")
        print("  nblm server-start")
        print("  nblm server-stop")
        sys.exit(1)

    action = sys.argv[1]

    if action == "server-start":
        ensure_server()
        print("Server started.")
        return

    if action == "server-stop":
        try:
            pid = int(LOCK_FILE.read_text().strip())
            os.kill(pid, 15)
        except Exception:
            pass
        LOCK_FILE.unlink(missing_ok=True)
        RESULT_FILE.unlink(missing_ok=True)
        print("Server stopped.")
        return

    if action == "list":
        result = send({"action": "list"})
    elif action == "query":
        if len(sys.argv) < 4:
            print("Usage: nblm query <notebook> <question>")
            sys.exit(1)
        result = send({"action": "query", "notebook": sys.argv[2], "question": sys.argv[3]})
    elif action == "sources":
        if len(sys.argv) < 3:
            print("Usage: nblm sources <notebook>")
            sys.exit(1)
        result = send({"action": "sources", "notebook": sys.argv[2]})
    elif action == "add-url":
        if len(sys.argv) < 4:
            print("Usage: nblm add-url <notebook> <url>")
            sys.exit(1)
        result = send({"action": "add-url", "notebook": sys.argv[2], "url": sys.argv[3]})
    elif action == "add-text":
        if len(sys.argv) < 5:
            print("Usage: nblm add-text <notebook> <title> <text>")
            sys.exit(1)
        result = send({"action": "add-text", "notebook": sys.argv[2], "title": sys.argv[3], "text": sys.argv[4]})
    else:
        print(f"Unknown command: {action}")
        sys.exit(1)

    if result.get("ok"):
        data = result["data"]
        if isinstance(data, list):
            for item in data:
                print(item)
        else:
            print(data)
    else:
        print(f"Error: {result.get('error', 'unknown')}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
